{
  "name": "bowtie-studio-pro",
  "version": "1.0.0",
  "type": "module",
  "description": "Professional bowtie diagram modeling tool for HSE and critical processes",
  "author": "PULSO-AI <contacto@pulso-ai.com>",
  "license": "MIT",
  "main": "electron/main.mjs",
  "homepage": "https://bowtiepro.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/pulso-ai/bowtie-studio-pro"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:client",
    "build:vercel": "vite build -c vite.vercel.config.ts && vite build -c vite.client.vercel.config.ts && node scripts/copy-vercel-public.mjs",
    "build:netlify": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && vite build -c vite.netlify.config.ts && vite build -c vite.client.config.ts && node scripts/copy-public.mjs",
    "preview": "wrangler pages dev",
    "deploy": "npm run build && wrangler pages deploy",
    "deploy:netlify": "npm run build:netlify && npx netlify-cli deploy --prod --dir=dist --functions=netlify/functions",
    "deploy:vercel": "npm run build:vercel && npx vercel deploy --prebuilt",
    "respaldar": "git add -A && git diff --cached --quiet || (git commit -m \"chore: respaldo $(date -u +%Y-%m-%d)\" && git push origin HEAD)",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "cf:provision": "node scripts/provision-d1.mjs",
    "build:client": "vite build -c vite.client.config.ts",
    "desktop": "electron .",
    "build:desktop": "node scripts/build-desktop.mjs",
    "desktop:pack": "electron-builder --publish never",
    "desktop:build": "npm run build:desktop && npm run desktop:pack"
  },
  "build": {
    "appId": "com.pulsoai.bowtie-studio",
    "productName": "Bowtie Studio Pro",
    "copyright": "Copyright © PULSO-AI",
    "files": [
      "electron/**/*",
      "dist/desktop/**/*",
      "package.json"
    ],
    "directories": { "output": "release" },
    "npmRebuild": true,
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "public/logo.png",
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "icon": "public/logo.png",
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "linux": { "target": ["AppImage"] },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/logo.png",
      "uninstallerIcon": "public/logo.png"
    }
  },
  "dependencies": {
    "@hono/node-server": "^1.19.0",
    "@libsql/client": "^0.17.2",
    "@xyflow/react": "^12.10.2",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "hono": "^4.12.12",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "tailwindcss": "^4.2.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0",
    "electron": "^35.1.2",
    "electron-builder": "^26.0.12"
  }
}
